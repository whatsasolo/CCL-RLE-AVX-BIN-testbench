# Visual Studio 작업공간과 사용자별 설정
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual C++ 빌드 출력 및 중간 파일
[Dd]ebug/
[Rr]elease/
x64/
x86/
Win32/
ARM/
ARM64/
ipch/
*.VC.db
*.VC.opendb
*.opendb
*.sdf
*.opensdf

# MSBuild가 생성하는 프로젝트 이름 기반 중간 폴더
/CCL_RLE_TEST/

# 네이티브 빌드 산출물
*.obj
*.pch
*.pdb
*.idb
*.ilk
*.iobj
*.ipdb
*.tlog
*.lastbuildstate
*.log
*.exe
*.dll
*.lib
*.exp

# 충돌 덤프와 임시 파일
*.dmp
*.tmp
*.temp
*.bak
*.userprefs
~$*

# 검사 및 시험 영상에는 생산 데이터가 포함될 수 있다.
*.jpg
*.jpeg
*.png
*.bmp
*.tif
*.tiff
